	НоваяСтрока.Организация = "ООО ""Автоматизация""";
	НоваяСтрока.НачалоРаботы = '20140122';
	НоваяСтрока.ОкончаниеРаботы = '20220331';
	НоваяСтрока.Должность = "Инженер";
	НоваяСтрока = Сотрудник2.ТрудоваяДеятельность.Добавить();
	НоваяСтрока.Организация = "ЗАО ""НПО СпецСвязь""";
	НоваяСтрока.НачалоРаботы = '20040520';
