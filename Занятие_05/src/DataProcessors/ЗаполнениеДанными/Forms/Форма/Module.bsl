	Строка.Количество = 5;
	Строка.Цена = 200;
	Строка.Сумма = 1000;

	Строка = Док2.Материалы.Добавить();
	Строка.Материал = Материал5.Ссылка;
	Строка.Количество = 10;
	Строка.Цена = 100;
	Строка.Сумма = 1000;

	Док2.Записать(РежимЗаписиДокумента.Проведение);

	// =============================================
	// Оказание услуги N1
	// =============================================
	Док3 = Документы.ОказаниеУслуги.СоздатьДокумент();
	Док3.Дата = ТекущаяДата();
	Док3.Склад = ОсновнойСклад;
	Док3.Клиент = Клиент1.Ссылка;
	Док3.Мастер = Сотрудник1.Ссылка;

	Строка = Док3.ПереченьНоменклатуры.Добавить();
	Строка.Номенклатура = Материал1.Ссылка;
	Строка.Количество = 1;
	Строка.Цена = 1000;
	Строка.Сумма = 1000;

	Строка = Док3.ПереченьНоменклатуры.Добавить();
	Строка.Номенклатура = Материал2.Ссылка;
	Строка.Количество = 2;
	Строка.Цена = 100;
	Строка.Сумма = 200;

	Док3.Записать(РежимЗаписиДокумента.Проведение);

КонецПроцедуры
