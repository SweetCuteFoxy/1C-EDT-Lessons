	ОсновнойСклад = Справочники.Склады.Основной;

	// =============================================
	// Приходная накладная N1 (ремонт телевизоров)
	// =============================================
	Док1 = Документы.ПриходнаяНакладная.СоздатьДокумент();
	Док1.Дата = ТекущаяДата();
	Док1.Склад = ОсновнойСклад;

	Строка = Док1.Материалы.Добавить();
