	НоваяСтрока.Должность = "Прораб";
	Сотрудник3.Записать();

	// =============================================
	// Справочник Номенклатура
	// =============================================
	ГруппаРадио = Справочники.Номенклатура.СоздатьГруппу();
	ГруппаРадио.Наименование = "Радиодетали";
